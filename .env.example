# ═══════════════════════════════════════════════════════════════════════════════
# Prayaas Environment Variables
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════════════════════════

# ── Environment ──────────────────────────────────────────────────────────────
ENVIRONMENT=development                    # development | production

# ── Gemini API Key (required for AI features) ────────────────────────────────
GOOGLE_API_KEY=your_google_api_key_here

# ── Database ─────────────────────────────────────────────────────────────────
# Dev:  sqlite:///./prayaas.db
# Prod: postgresql://prayaas_app:PASSWORD@db:5432/prayaas
DATABASE_URL=sqlite:///./prayaas.db

# ── Redis (optional in dev — lockout/tokens degrade gracefully) ──────────────
REDIS_URL=redis://localhost:6379/0

# ── JWT Keys (RS256) ─────────────────────────────────────────────────────────
# In dev: auto-generated if not set (ephemeral keys)
# In prod: set these to PEM-formatted RSA keys
# Generate: openssl genrsa 2048 > private.pem
#           openssl rsa -in private.pem -pubout > public.pem
# JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# ── PII Encryption Key ──────────────────────────────────────────────────────
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# PII_ENCRYPTION_KEY=your_fernet_key_here

# ── CORS Origins ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ── AI Token Budget ──────────────────────────────────────────────────────────
AI_TOKEN_BUDGET_PER_USER=50000

# ── Confidence-Gated Pipeline ────────────────────────────────────────────────
# Outputs scoring at or above this confidence are auto-resolved (no human
# review). Lower it to be more conservative; raise it to push more drafts
# into manual review.
PRAYAAS_AUTO_RESOLVE_THRESHOLD=0.78

# ── Embeddings (semantic dedup + RAG over LMC docs) ──────────────────────────
# `gemini-embedding-001` returns 3072-d vectors via the v1beta API.
PRAYAAS_EMBEDDING_MODEL=gemini-embedding-001
PRAYAAS_EMBEDDING_DIM=3072

# ── Docker Compose (production only) ─────────────────────────────────────────
# DB_USER=prayaas_app
# DB_PASSWORD=change_me_to_a_strong_password
# DB_NAME=prayaas
# REDIS_PASSWORD=change_me_to_a_strong_password
# TAG=latest
# NEXT_PUBLIC_API_URL=https://api.prayaas.app
